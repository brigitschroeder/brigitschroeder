---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "One Hundred Investigations — healthcare analytics research notebook by Brigit Schroeder" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | One Hundred Investigations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title">One Hundred Investigations</a>
        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <ul id="nav-menu">
          <li><a href="/investigations">Investigations</a></li>
          <li><a href="/notes">Notes</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </nav>
    </header>
    <script>
      const toggle = document.querySelector('.nav-toggle');
      const menu = document.getElementById('nav-menu');
      toggle?.addEventListener('click', () => {
        const open = menu?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
      });
    </script>
    <main>
      <slot />
    </main>
    <footer>
      <p>Brigit Schroeder &mdash; Healthcare Analytics Research Notebook</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-bg: #fafaf8;
    --color-surface: #ffffff;
    --color-border: #e5e5e0;
    --color-text: #1a1a1a;
    --color-text-muted: #6b6b6b;
    --color-accent: #2563eb;
    --color-accent-light: #eff6ff;
    --color-tag-bg: #f0f0ec;
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-serif: 'Source Serif 4', Georgia, serif;
    --font-mono: 'JetBrains Mono', monospace;
    --max-width: 780px;
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  nav ul a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }

  nav ul a:hover { color: var(--color-accent); }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: opacity 0.15s;
  }

  @media (max-width: 600px) {
    nav {
      flex-wrap: wrap;
      gap: 0;
      padding: 0.75rem 1.25rem;
    }

    .site-title { flex: 1; }

    .nav-toggle { display: flex; }

    nav ul {
      display: none;
      flex-direction: column;
      gap: 0;
      width: 100%;
      border-top: 1px solid var(--color-border);
      margin-top: 0.75rem;
    }

    nav ul.open { display: flex; }

    nav ul li a {
      display: block;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--color-border);
    }
  }

  main {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
    width: 100%;
  }

  footer {
    border-top: 1px solid var(--color-border);
    text-align: center;
    padding: 1.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  h1 { font-family: var(--font-serif); font-size: 2rem; line-height: 1.25; margin-bottom: 0.5rem; }
  h2 { font-family: var(--font-serif); font-size: 1.4rem; margin: 2rem 0 0.75rem; }
  h3 { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  p { margin-bottom: 1rem; }
  a { color: var(--color-accent); }

  .tag {
    display: inline-block;
    background: var(--color-tag-bg);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
  }

  .status {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .status-draft { background: #f5f5f0; color: #888; }
  .status-in-progress { background: #fef9c3; color: #854d0e; }
  .status-complete { background: #dcfce7; color: #166534; }

  .prose h2 { font-family: var(--font-serif); font-size: 1.3rem; margin: 2.5rem 0 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--color-border); }
  .prose p { font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.75; color: #2a2a2a; }
  .prose code { font-family: var(--font-mono); font-size: 0.85em; background: var(--color-tag-bg); padding: 0.15em 0.4em; border-radius: 3px; }
  .prose pre { background: #1e1e1e; color: #d4d4d4; padding: 1.25rem; border-radius: 6px; overflow-x: auto; margin: 1.5rem 0; }
  .prose pre code { background: none; padding: 0; font-size: 0.9rem; }
  .prose ul, .prose ol { font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.75; color: #2a2a2a; padding-inline-start: 1.5rem; margin-bottom: 1rem; }
  .prose table { border-collapse: collapse; width: 100%; margin-bottom: 1.5rem; }
  .prose th, .prose td { border: 1px solid var(--color-border); padding: 0.5rem 0.75rem; text-align: left; }
  .prose th { background: var(--color-tag-bg); font-weight: 600; }
  .prose img { max-width: 100%; height: auto; }
</style>
